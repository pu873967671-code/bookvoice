{
  "name": "bookvoice",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm --workspace @bookvoice/api run dev",
    "dev:worker": "npm --workspace @bookvoice/worker run dev",
    "dev:web": "npm --workspace @bookvoice/web run dev",
    "start:api": "npm --workspace @bookvoice/api run start",
    "start:worker": "npm --workspace @bookvoice/worker run start",
    "start:web": "npm --workspace @bookvoice/web run start"
  }
}
